# Copy to .env for local/private overrides. Do not commit .env.

# Public service endpoints. Empty stats URL disables profile/ghost stats.
FREEPLAY_SIGNALING_URL=https://your-signaling-service.example.com
FREEPLAY_STATS_URL=https://your-stats-service.example.com

# Discord Rich Presence application id.
FREEPLAY_DISCORD_CLIENT_ID=your-discord-application-id

# Optional private webhook. Leave empty unless you own the destination channel.
FREEPLAY_DISCORD_WEBHOOK_URL=

# Optional ffmpeg path for Ctrl+R MP4 clip encoding.
# If unset, Freeplay searches PATH, the app folder, and tools/ffmpeg/.
FREEPLAY_FFMPEG=

