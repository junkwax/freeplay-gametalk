# Copy to .env for local/private overrides. Do not commit .env.

# Public service endpoints. Empty stats URL disables profile/ghost stats.
FREEPLAY_SIGNALING_URL=https://xband-signaling-rovy6ybw3q-uc.a.run.app
FREEPLAY_STATS_URL=https://freeplay-stats-681135711161.us-central1.run.app

# Optional username seed. Leave UNSET for normal use: a fresh install then
# auto-generates a Wu-style name and asks the player to confirm it before
# their first match. Only set this for headless/scripted runs where you want
# a fixed name and want to skip the confirm screen.
# FREEPLAY_USERNAME=

# Discord Rich Presence application id.
FREEPLAY_DISCORD_CLIENT_ID=1496704771627679804

# Optional private webhook. Leave empty unless you own the destination channel.
FREEPLAY_DISCORD_WEBHOOK_URL=

# Optional ffmpeg path for Ctrl+R MP4 clip encoding.
# If unset, Freeplay searches PATH, the app folder, and tools/ffmpeg/.
FREEPLAY_FFMPEG=

# Optional local renderer test overrides. Profiles: auto, hardware,
# hardware_vsync, software. Use --render-probe to print the selected backend.
# Driver can force an SDL backend such as direct3d11.
# FREEPLAY_RENDER_PROFILE=hardware
# FREEPLAY_RENDER_DRIVER=direct3d11

# Optional boot-time video filter override for local/private render testing.
# Filters: sharp, smooth, scanlines, crt_lite, crt_arcade, crt_deluxe,
# crt_shader, crt_arcade_gl, crt_pvm_gl, crt_cabinet, pvm_sharp.
# CRT shader filters force OpenGL on launch.
# FREEPLAY_VIDEO_FILTER=crt_shader
